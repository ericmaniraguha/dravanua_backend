# ============================================
# DRA VANUA GROUP LTD — Project Metadata
# ============================================
PROJECT_NAME="DRA VANUA GROUP LTD API"
PROJECT_VERSION="1.2.4"
PROJECT_BRAND_SLOGAN="DRA VANUA GROUP LTD — Here to Create 🌿"
API_V1_STR="/api/v1"
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Server Binding
PROTOCOL=http
HOST=localhost
DRAVANUA_PORT=8003

# =========================================================
# DATABASE CONFIGURATION (Sequelize / MySQL)
# =========================================================
DB_DIALECT=mysql
DRAVANUA_DB_HOST=localhost
DRAVANUA_DB_NAME=dravanua_db
DRAVANUA_DB_USER=root
DRAVANUA_DB_PASSWORD=your_secure_password
DRAVANUA_DB_PORT=3306

# MySQL Root Password (Used by Docker)
MYSQL_ROOT_PASSWORD=SystemRoot@123

# =========================================================
# INITIAL SUPER ADMIN PROVISIONING
# =========================================================
# Seeded automatically during first setup
ADMIN_NAME="Dravanua Admin"
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123

# =========================================================
# SECURITY & AUTHENTICATION
# =========================================================
# Backend Port is controlled by DRAVANUA_PORT
JWT_SECRET="your_jwt_secret_here"
JWT_REFRESH_SECRET="your_refresh_secret_here"
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# =========================================================
# DROPBOX INTEGRATION (Cloud Vault)
# =========================================================
DROPBOX_APP_KEY=your_key
DROPBOX_APP_SECRET=your_secret
DROPBOX_ACCESS_TOKEN=your_token
DROPBOX_REFRESH_TOKEN=your_refresh_token
DROPBOX_ROOT_FOLDER=/DraVanuaHub

# =========================================================
# EMAIL (SMTP) SERVICE
# =========================================================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD="your_app_password"
SMTP_FROM=your_email@gmail.com

# =========================================================
# FRONTEND CONFIGURATION
# =========================================================
FRONTEND_PORT=5174
FRONTEND_URL=http://localhost:5174
VITE_API_BASE_URL=http://localhost:8003