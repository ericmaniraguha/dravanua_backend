PROJECT_NAME="DRAVANUA HUB API"
PROJECT_VERSION="1.2.4"
PROJECT_BRAND_SLOGAN="Your Brand Slogan Here"
API_V1_STR="/api/v1"
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Server Binding
PROTOCOL=http
DEFAULT_HOST=api.example.com

# Dev binding (local)
HOST=localhost
DRAVANUA_HOST=localhost
DRAVANUA_PORT=8003

# =========================================================
# DATABASE CONFIGURATION
# =========================================================
DB_DIALECT=mysql
DRAVANUA_DB_HOST=localhost
DRAVANUA_DB_NAME=your_database_name
DRAVANUA_DB_USER=your_database_user
DRAVANUA_DB_PASSWORD=your_database_password
DRAVANUA_DB_PORT=3306

MYSQL_ROOT_PASSWORD=your_mysql_root_password

# Default Super Admin (For auto-provisioning)
ADMIN_NAME="Admin Name"
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_this_password

# ============================================
# DROPBOX INTEGRATION
# ============================================
DROPBOX_APP_KEY=your_dropbox_app_key
DROPBOX_APP_SECRET=your_dropbox_app_secret
DROPBOX_ACCESS_TOKEN=your_dropbox_access_token
DROPBOX_REFRESH_TOKEN=your_dropbox_refresh_token

# Dropbox Storage Configuration
DROPBOX_ROOT_FOLDER=/YourApp
DROPBOX_MEDIA_FOLDER=/YourApp/media
DROPBOX_DOCUMENTS_FOLDER=/YourApp/documents
DROPBOX_BACKUPS_FOLDER=/YourApp/backups

# Dropbox Upload Settings
DROPBOX_MAX_FILE_SIZE=150
DROPBOX_ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,pdf,docx,xlsx,pptx,zip
DROPBOX_AUTO_BACKUP_ENABLED=true
DROPBOX_BACKUP_SCHEDULE=daily

# ============================================
# BACKEND CONFIGURATION
# ============================================
BACKEND_PORT=8003
SECRET_KEY=your_secret_key_here
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
BACKEND_CORS_ORIGINS=https://www.example.com,https://example.com,http://localhost:5174,http://localhost:5173

# ============================================
# FRONTEND CONFIGURATION
# ============================================
FRONTEND_PORT=5174
FRONTEND_URL=http://localhost:5174
VITE_API_BASE_URL=https://api.example.com

# ============================================
# EMAIL/SMTP CONFIGURATION
# ============================================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_email_app_password
SMTP_FROM=your_email@example.com